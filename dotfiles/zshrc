# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="powerlevel10k/powerlevel10k"

export SSH_ASKPASS=/usr/bin/ksshaskpass

plugins=(git)

source $ZSH/oh-my-zsh.sh

# ── Aliases ────────────────────────────────────────────────────────────────────
alias python='python3'
alias pip='pip3'
alias cc='claude'
alias ccmcp='claude mcp list'

# ── PATH ───────────────────────────────────────────────────────────────────────
export PATH="$HOME/.npm-global/bin:$HOME/.local/bin:$PATH"

# ── 1Password CLI completions ──────────────────────────────────────────────────
if command -v op &>/dev/null; then
  eval "$(op completion zsh 2>/dev/null)"
fi

# ── Distrobox ─────────────────────────────────────────────────────────────────
if [[ -n "${CONTAINER_ID:-}" ]]; then
  alias tailscale='distrobox-host-exec tailscale'
fi

# ── Powerlevel10k ─────────────────────────────────────────────────────────────
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ── tmux auto-launch ──────────────────────────────────────────────────────────
# Skips when: already in tmux, inside VS Code, or NO_TMUX=1 is set.
if [[ -o interactive ]]; then
  [[ -n "$TMUX" ]] && return
  [[ "$TERM_PROGRAM" == "vscode" ]] && return
  [[ -n "${NO_TMUX-}" ]] && return

  if command -v tmux >/dev/null 2>&1 && [[ -x "$HOME/.local/bin/tmux-homelab" ]]; then
    exec "$HOME/.local/bin/tmux-homelab"
  fi
fi
