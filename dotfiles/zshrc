# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="powerlevel10k/powerlevel10k"

export SSH_ASKPASS=/usr/bin/ksshaskpass

plugins=(git)

source $ZSH/oh-my-zsh.sh

# ── Aliases ────────────────────────────────────────────────────────────────────
alias python='python3'
alias pip='pip3'
alias cc='claude'
alias ccmcp='claude mcp list'

# ── PATH ───────────────────────────────────────────────────────────────────────
export PATH="$HOME/.npm-global/bin:$HOME/.local/bin:$PATH"

# ── 1Password CLI completions ──────────────────────────────────────────────────
if command -v op &>/dev/null; then
  eval "$(op completion zsh 2>/dev/null)"
fi

# ── Distrobox ─────────────────────────────────────────────────────────────────
if [[ -n "${CONTAINER_ID:-}" ]]; then
  alias tailscale='distrobox-host-exec tailscale'
  # Podman remote passthrough: all podman/docker commands proxy to host Podman.
  # Distrobox mounts the host's /run under /run/host/run — XDG_RUNTIME_DIR inside
  # the container is a Distrobox-managed tmpfs, not the host's runtime dir.
  # Requires: systemctl --user enable --now podman.socket on the Aurora-DX host.
  export CONTAINER_HOST="unix:///run/host/run/user/${UID}/podman/podman.sock"
  export DOCKER_HOST="unix:///run/host/run/user/${UID}/podman/podman.sock"
fi

# ── Powerlevel10k ─────────────────────────────────────────────────────────────
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ── Kubernetes ────────────────────────────────────────────────────────────────
kubemerge() {
  # Rebuild ~/.kube/config by merging all ~/.kube/*.yaml cluster files.
  # Each cluster should have its own *.yaml file for full portability.
  local yamls=(~/.kube/*.yaml(N))
  [[ ${#yamls[@]} -eq 0 ]] && { echo "No cluster configs found in ~/.kube/*.yaml"; return 1; }
  cp ~/.kube/config ~/.kube/config.bak
  local joined
  joined=$(IFS=:; echo "${yamls[*]}")
  KUBECONFIG="$joined" kubectl config view --flatten > /tmp/kubeconfig-merged \
    && mv /tmp/kubeconfig-merged ~/.kube/config \
    && chmod 600 ~/.kube/config \
    && echo "Merged ${#yamls[@]} config(s) → ~/.kube/config"
}

# ── tmux auto-launch ──────────────────────────────────────────────────────────
# Skips when: already in tmux, inside VS Code, or NO_TMUX=1 is set.
if [[ -o interactive ]]; then
  [[ -n "$TMUX" ]] && return
  [[ "$TERM_PROGRAM" == "vscode" ]] && return
  [[ -n "${NO_TMUX-}" ]] && return

  if command -v tmux >/dev/null 2>&1 && [[ -x "$HOME/.local/bin/tmux-homelab" ]]; then
    exec "$HOME/.local/bin/tmux-homelab"
  fi
fi
