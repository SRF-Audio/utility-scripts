# ~/.ssh/config — router only, all entries live in config.d/
#
# Numbering convention:
#   10 — global defaults
#   20 — personal / homelab static hosts
#   30 — homelab k3s nodes          (written by ansible: cluster-connector)
#   35 — hetzner node               (written by ansible: cluster-connector)
#   40 — synology NAS               (written by ansible: synology-backup)
#   50 — work hosts
#
# SSH reads entries in order; first match wins per directive.

Include ~/.ssh/config.d/*.conf
# BEGIN NEXGEN DEV CLUSTER
# NexGen SSH profile for dev
# Managed by Ansible - do not edit manually.

Host nexgen-dev-proxy-tunnel
  HostName 52.95.251.48
  User ec2-user
  IdentityFile /home/devuser/.ssh/nexgen-dev-key.pem
  IdentitiesOnly yes
  DynamicForward 127.0.0.1:1080
  ExitOnForwardFailure yes
  StrictHostKeyChecking accept-new
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 60m
  ServerAliveInterval 30
  ServerAliveCountMax 3

Host nexgen-dev-bastion
  HostName 52.95.251.48
  User ec2-user
  IdentityFile /home/devuser/.ssh/nexgen-dev-key.pem
  IdentitiesOnly yes
  StrictHostKeyChecking accept-new
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 60m
  ServerAliveInterval 30
  ServerAliveCountMax 3

