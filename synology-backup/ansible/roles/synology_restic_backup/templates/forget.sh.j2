#!/bin/bash
# Managed by Ansible role synology_restic_backup — do not edit by hand.
# Re-run the Ansible playbook to update this file.
#
# Runs restic forget (with --prune) against snapshots tagged by this role.
# Retention policy is set by Ansible variables — change defaults/main.yml
# and re-run the playbook; do not edit this file directly.
# Safe to invoke manually; concurrent runs are prevented via a lock directory.
set -euo pipefail

readonly LOCK_DIR="/var/lock/restic-backup-forget.lock"
readonly LOG_FILE="{{ synology_restic_backup_log_dir }}/forget.log"
readonly RESTIC="{{ synology_restic_backup_restic_install_dir }}/restic"
readonly PASSWORD_FILE="{{ synology_restic_backup_config_dir }}/.restic-password"

if ! mkdir "${LOCK_DIR}" 2>/dev/null; then
    echo "$(date -Iseconds) [forget] Lock exists at ${LOCK_DIR}; another instance is running. Exiting." \
        >> "${LOG_FILE}"
    exit 0
fi
trap 'rmdir "${LOCK_DIR}" 2>/dev/null || true' EXIT INT TERM

{
    echo "=== $(date -Iseconds) [forget] START ==="

    export RESTIC_REPOSITORY="sftp:storagebox:{{ synology_restic_backup_storagebox_repo_path }}"
    export RESTIC_PASSWORD
    RESTIC_PASSWORD=$(cat "${PASSWORD_FILE}")

    "${RESTIC}" forget \
        --prune \
        --tag "{{ synology_restic_backup_snapshot_tag }}" \
        --keep-daily  {{ synology_restic_backup_retention_keep_daily }} \
        --keep-weekly {{ synology_restic_backup_retention_keep_weekly }} \
        --keep-monthly {{ synology_restic_backup_retention_keep_monthly }} \
        --verbose

    echo "=== $(date -Iseconds) [forget] END rc=$? ==="
} >> "${LOG_FILE}" 2>&1
