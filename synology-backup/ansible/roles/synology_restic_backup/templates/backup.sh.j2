#!/bin/bash
# Managed by Ansible role synology_restic_backup — do not edit by hand.
# Re-run the Ansible playbook to update this file.
#
# Backs up each configured share as an independent restic invocation so that
# a mid-transfer SSH failure only loses progress on the current share, not
# the entire job.  Restic content-level deduplication means data already
# uploaded by a prior (failed) monolithic run is not re-sent.
set -euo pipefail

readonly LOCK_DIR="/var/lock/restic-backup-backup.lock"
readonly LOG_FILE="{{ synology_restic_backup_log_dir }}/backup.log"
readonly RESTIC="{{ synology_restic_backup_restic_install_dir }}/restic"
readonly PASSWORD_FILE="{{ synology_restic_backup_config_dir }}/.restic-password"
readonly ALERT_CMD="{{ synology_restic_backup_alert_command }}"
readonly JOB="backup"
readonly MAX_ATTEMPTS={{ synology_restic_backup_max_attempts | default(4) }}
readonly RETRY_DELAY={{ synology_restic_backup_retry_delay | default(300) }}

_log() { echo "$(date -Iseconds) [${JOB}] $1"; }

_alert() {
    local message="$1"
    _log "ALERT: ${message}"
    if [[ -n "${ALERT_CMD}" ]]; then
        eval "${ALERT_CMD}" <<< "${message}" 2>> "${LOG_FILE}" || true
    fi
}

_backup_share() {
    local share="$1"
    local share_name
    share_name=$(basename "${share}")
    local attempt=1
    local rc=1

    while [[ ${attempt} -le ${MAX_ATTEMPTS} ]]; do
        if [[ ${attempt} -gt 1 ]]; then
            _log "[${share_name}] Attempt ${attempt}/${MAX_ATTEMPTS} — unlocking repo and retrying in ${RETRY_DELAY}s"
            "${RESTIC}" unlock 2>&1 || true
            sleep "${RETRY_DELAY}"
        fi

        _log "[${share_name}] Attempt ${attempt}/${MAX_ATTEMPTS} — starting backup"

        set +e
        GOMAXPROCS={{ synology_restic_backup_gomaxprocs }} \
        "${RESTIC}" backup \
            --one-file-system \
            --compression {{ synology_restic_backup_compression }} \
            --tag "{{ synology_restic_backup_snapshot_tag }}" \
            --verbose \
            "${EXCLUDES[@]}" \
            "${share}"
        rc=$?
        set -e

        if [[ ${rc} -eq 0 ]]; then
            _log "[${share_name}] Completed successfully"
            return 0
        fi

        _log "[${share_name}] Attempt ${attempt}/${MAX_ATTEMPTS} failed with rc=${rc}"
        attempt=$(( attempt + 1 ))
    done

    _alert "${share_name} failed after ${MAX_ATTEMPTS} attempts with exit code ${rc}. Check ${LOG_FILE} for details."
    return 1
}

# Acquire lock — mkdir is atomic on all DSM-supported filesystems.
if ! mkdir "${LOCK_DIR}" 2>/dev/null; then
    _alert "Lock contention: another ${JOB} instance is running (${LOCK_DIR} exists). This run was skipped."
    exit 1
fi
trap 'rmdir "${LOCK_DIR}" 2>/dev/null || true' EXIT INT TERM

{
    _log "START"

    export RESTIC_REPOSITORY="sftp:storagebox:{{ synology_restic_backup_storagebox_repo_path }}"
    export RESTIC_PASSWORD
    RESTIC_PASSWORD=$(cat "${PASSWORD_FILE}")

    EXCLUDES=(
{% for exclude in synology_restic_backup_excludes %}
        --exclude="{{ exclude }}"
{%- endfor %}
    )

    SHARES=(
{% for path in synology_restic_backup_backup_paths %}
        "{{ path }}"
{%- endfor %}
    )

    failed=()
    for share in "${SHARES[@]}"; do
        if [[ ! -d "${share}" ]]; then
            _log "$(basename "${share}") does not exist, skipping"
            continue
        fi
        if ! _backup_share "${share}"; then
            failed+=("${share}")
        fi
    done

    if [[ ${% raw %}{#{% endraw %}failed[@]} -gt 0 ]]; then
        _log "END — ${% raw %}{#{% endraw %}failed[@]} share(s) failed: ${failed[*]}"
        _alert "${% raw %}{#{% endraw %}failed[@]} share(s) failed: ${failed[*]}. Check ${LOG_FILE} for details."
        exit 1
    fi

    _log "END — all shares completed successfully"
} >> "${LOG_FILE}" 2>&1
