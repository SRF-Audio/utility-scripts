{
  "model": "claude-fable-5[1m]",
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(op account *)",
      "Bash(op item *)",
      "Bash(op vault *)",
      "Bash(python3 *)"
    ]
  },
  "mcpServers": {
    "fetch": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "github": {
      "args": [],
      "command": "/home/sfroeber/.claude/mcp-wrappers/github.sh",
      "type": "stdio"
    },
    "trello": {
      "args": [],
      "command": "/home/sfroeber/.claude/mcp-wrappers/trello.sh",
      "type": "stdio"
    }
  }
}
